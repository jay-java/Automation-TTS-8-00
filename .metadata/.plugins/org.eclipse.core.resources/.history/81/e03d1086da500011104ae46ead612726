package core;

public class P006_Loops {
	public static void main(String[] args) {
		// ( < , ++), ( > , --)
		// 1.for loop
		// for(initialization;condition;incre/decre){body}
		System.out.println("for loop increment");
		for (int i = 1; i <= 10; i++) {
			System.out.println(i);
		}
		System.out.println("for loop decrement");
		for (int i = 10; i >= 1; i--) {
			System.out.println(i);
		}
		// 2.while loop
		//while(condition){body}
		// 3.do while loop
		// 4.for each loop
	}
}
